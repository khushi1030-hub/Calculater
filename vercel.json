{
  "version": 2,
  "builds": [
    {
      "src": "./backend",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "512mb",
        "pythonVersion": "3.11"
      }
    },
    {
      "src": "./frontend",
      "use": "@vercel/static"
    }
  ],
  "env": {
    "PORT": "80"
  }
}